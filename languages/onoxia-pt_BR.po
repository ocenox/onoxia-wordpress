#: admin/views/settings.php:62
msgid "The bot automatically learns the content of your website."
msgstr "O bot aprende automaticamente o conteúdo do seu site."

#: admin/views/settings.php:65
msgid "Sync pages"
msgstr "Sincronizar páginas"

#: admin/views/settings.php:69
